# SlitCam Pi camera runtime configuration

# ── USB gadget ────────────────────────────────────────────────────────────────
SLITCAM_CONFIGFS_ROOT=/sys/kernel/config
SLITCAM_USB_GADGET_NAME=slitcam0
SLITCAM_USB_VENDOR_ID=0x0525
SLITCAM_USB_PRODUCT_ID=0xa4a2
SLITCAM_USB_SERIAL=SLITCAM-0001
SLITCAM_USB_MANUFACTURER=slitcam-pi
SLITCAM_USB_PRODUCT=SlitCam Pi Camera
SLITCAM_USB_CONFIGURATION=UVC
SLITCAM_USB_MAX_POWER_MA=500
SLITCAM_CAMERA_ID=0
SLITCAM_UVC_GADGET_BIN=/usr/local/bin/uvc-gadget
SLITCAM_UDC_WAIT_SECS=60
# Optional: pin a specific UDC name
# SLITCAM_UDC_NAME=3f980000.usb

# ── Video quality ─────────────────────────────────────────────────────────────
# Lower resolution = less lag. Start at 640x480 / 30fps and increase
# once the system is stable.
# Supported resolutions: 640x480, 1280x720, 1920x1080
SLITCAM_UVC_RESOLUTION=640x480
SLITCAM_UVC_FRAMERATE=30

# ── TMC2209 motion control ────────────────────────────────────────────────────
# UART0 on Pi Zero 2W = GPIO14 (TX) + GPIO15 (RX) = /dev/ttyAMA0
SLITCAM_UART_DEVICE=/dev/ttyAMA0
SLITCAM_UART_BAUD=115200
SLITCAM_UART_WAIT_SECS=10

# StallGuard threshold: 0=most sensitive, 255=least sensitive.
# Tune this after wiring — start at 80 and adjust until homing
# detects the endstop without false triggers during normal moves.
SLITCAM_STALLGUARD_THRESHOLD=80

# Steps to back off from the endstop after a stall is detected.
SLITCAM_HOME_BACKOFF_STEPS=50

# Motor current (0–31 RMS scale, where 31 = max driver current).
# Set to match your motor's rated current and the TMC2209 Rsense resistor.
SLITCAM_MOTOR_RUN_CURRENT=20
SLITCAM_MOTOR_HOLD_CURRENT=8
