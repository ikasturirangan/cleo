# SlitCam Pi camera runtime configuration

# ── USB gadget ────────────────────────────────────────────────────────────────
SLITCAM_CONFIGFS_ROOT=/sys/kernel/config
SLITCAM_USB_GADGET_NAME=slitcam0
SLITCAM_USB_VENDOR_ID=0x0525
SLITCAM_USB_PRODUCT_ID=0xa4a2
SLITCAM_USB_SERIAL=SLITCAM-0001
SLITCAM_USB_MANUFACTURER=slitcam-pi
SLITCAM_USB_PRODUCT=SlitCam Pi Camera
SLITCAM_USB_CONFIGURATION=UVC
SLITCAM_USB_MAX_POWER_MA=500
SLITCAM_CAMERA_ID=0
SLITCAM_UVC_GADGET_BIN=/usr/local/bin/uvc-gadget
SLITCAM_UDC_WAIT_SECS=60
# Optional: pin a specific UDC name
# SLITCAM_UDC_NAME=3f980000.usb

# ── Video quality ─────────────────────────────────────────────────────────────
# Lower resolution = less lag. 640x480@30 is the safest starting point.
# Supported: 640x480, 1280x720, 1920x1080
SLITCAM_UVC_RESOLUTION=640x480
SLITCAM_UVC_FRAMERATE=30

# ── TMC2209 step/dir GPIO (BCM numbering) ─────────────────────────────────────
# Pin 7  → GPIO4  → STEP
# Pin 11 → GPIO17 → DIR
# Pin 13 → GPIO27 → EN   (active LOW)
# Pin 15 → GPIO22 → DIAG (input, HIGH = stall)
SLITCAM_GPIO_STEP=4
SLITCAM_GPIO_DIR=17
SLITCAM_GPIO_EN=27
SLITCAM_GPIO_DIAG=22

# Step pulse half-period in microseconds (500µs = ~1000 steps/sec at 8x microstep).
# Decrease to move faster; increase if motor skips steps.
SLITCAM_STEP_DELAY_US=500

# Maximum steps to travel during homing before giving up.
SLITCAM_HOME_MAX_STEPS=10000

# Steps to back off from the endstop after stall is detected.
SLITCAM_HOME_BACKOFF_STEPS=100
