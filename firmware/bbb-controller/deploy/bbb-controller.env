# SlitCam BeagleBone controller runtime configuration.
# This file is loaded by the systemd service.  Edit values to match your wiring.

# V4L2 device node for the Pi camera (auto-discovered; override if needed).
SLITCAM_VIDEO_DEVICE=/dev/video0

# Address the HTTP API will bind to (accessible from the host network).
SLITCAM_API_BIND=0.0.0.0:8080

# I2C bus wired to the DLP2000 DLPC2607 (BeagleBone P9 header I2C2 = /dev/i2c-2).
SLITCAM_I2C_BUS=/dev/i2c-2

# 7-bit I2C address of the DLPC2607 (default when address pins pulled low).
SLITCAM_DLP_I2C_ADDR=0x1b

# UART connected to TMC2209 single-wire UART (BeagleBone P9 UART1 = /dev/ttyS1).
SLITCAM_UART_DEVICE=/dev/ttyS1
SLITCAM_UART_BAUD=115200

# USB IDs of the Pi camera gadget — must match pi-camera deploy/pi-camera.env.
SLITCAM_CAMERA_USB_VENDOR_ID=0x0525
SLITCAM_CAMERA_USB_PRODUCT_ID=0xa4a2

# Seconds to wait for the Pi camera to appear on USB before failing.
SLITCAM_CAMERA_WAIT_SECS=30

# Calibration file path (created on first save; loaded on startup if present).
SLITCAM_CALIBRATION_PATH=/etc/slitcam/calibration.json
